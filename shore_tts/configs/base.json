{
    "model":
    {
    "vocab_size": 223,
    "text_embedding_dim": 128,
    "text_hidden_dim": 128,
    "text_n_layers": 4,
    "text_n_heads": 8,
    "text_d_model": 128,
    "n_mels": 128,
    "decoder_d_model": 128,
    "decoder_n_heads": 8,
    "decoder_n_layers": 6,
    "decoder_d_ff": 512,
    "postnet_n_layers": 5,
    "postnet_kernel_size": 5,
    "postnet_n_channels": 512,
    "dropout": 0.1,
    "max_text_len": 1024,
    "max_mel_len": 2048
    },
    "training":
    {
        "batch_size": 2,
        "epochs": 50,
        "learning_rate": 1e-4,
        "gradient_accumulation_steps": 4,
        "seed": 42,
        "save_dir": "checkpoints/tts",
        "optimizer": "AdamW",
        "distributed":{
            "enabled": true,
            "world_size": 1, 
            "rank": 0,
            "dist_backend": "nccl",
            "dist_url": "tcp://localhost:12345"
        },
        "data":{
            "mel_list_path": "data/mel_list.list",
            "pinyin_list_path": "data/pinyin_list.list"
        }
    }
}