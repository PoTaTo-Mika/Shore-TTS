{
    "model": {
        "phoneme_vocab_size": 49,
        "embedding_dim": 256,
        "encoder_prenet_hidden_dim": 256,
        "encoder_prenet_output_dim": 128,
        "cbhg_k": 16,
        "cbhg_conv_channels": 128,
        "cbhg_highway_layers": 4,
        "attention_dim": 128,
        "decoder_prenet_hidden_dim": 256,
        "decoder_prenet_output_dim": 128,
        "decoder_rnn_dim": 256,
        "num_mels": 80,
        "max_decoder_steps": 1024
    },
    "audio": {
        "sample_rate": 22050,
        "n_fft": 1024,
        "win_length": 1024,
        "hop_length": 256,
        "n_mels": 80,
        "f_min": 0,
        "f_max": 8000,
        "center": false
    },
    "dataset": {
        "text_subdir": "texts",
        "mel_subdir": "mels",
        "pad_token_id": 0,
        "eos_token_id": 1,
        "add_eos": true,
        "max_text_length": 200,
        "max_mel_length": 1000
    },
    "training": {
        "device": "cuda",
        "data_dir": "data",
        "batch_size": 32,
        "epochs": 100,
        "learning_rate": 4e-4,
        "weight_decay": 1e-5,
        "grad_clip": 1.0,
        "save_every_steps": 100, 
        "save_every_epoch": 10,
        "log_every_steps": 100,
        "num_workers": 32,
        "optimizer": {
            "name": "AdamW",
            "betas": [0.9, 0.999],
            "eps": 1e-8
        },
        "scheduler": {
            "name": "CosineAnnealingLR",
            "T_max": 100,
            "eta_min": 1e-4
        },
        "loss": {
            "mel_loss_weight": 1.0,
            "stop_loss_weight": 0.5,
            "mel_loss_type": "l1",
            "stop_loss_type": "BCEWithLogitsLoss"
        }
    },
    "evaluation": {
        "split_rate": 0.1,
        "batch_size": 16,
        "eval_every_steps": 100
    },
    "checkpoint": {
        "save_dir": "./checkpoints/bone"
    },
    "logging": {
        "log_dir": "./logs",
        "tensorboard": true,
        "log_level": "INFO"
    },
    "inference": {
        "temperature": 1.0,
        "stop_threshold": 0.5,
        "max_decoder_ratio": 10.0
    }
}